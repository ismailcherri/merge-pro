{
    "name": "merge-pro",
    "displayName": "MergePro",
    "publisher": "ismailcherri",
    "description": "IntelliJ-style three-pane merge conflict resolver for VS Code.",
    "version": "0.1.0",
    "license": "MIT",
    "icon": "assets/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/ismailcherri/merge-pro.git"
    },
    "bugs": {
        "url": "https://github.com/ismailcherri/merge-pro/issues"
    },
    "homepage": "https://github.com/ismailcherri/merge-pro#readme",
    "qna": "marketplace",
    "galleryBanner": {
        "color": "#3C2F2F",
        "theme": "dark"
    },
    "engines": {
        "vscode": "^1.85.0",
        "node": ">=20.0.0"
    },
    "categories": [
        "SCM Providers",
        "Other"
    ],
    "keywords": [
        "git",
        "merge",
        "conflict",
        "diff",
        "three-way",
        "intellij",
        "resolve",
        "merge-tool",
        "vcs"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "views": {
            "scm": [
                {
                    "type": "webview",
                    "id": "mergePro.panel",
                    "name": "MergePro",
                    "icon": "$(git-merge)",
                    "when": "true"
                }
            ]
        },
        "commands": [
            {
                "command": "mergePro.openEditor",
                "title": "MergePro: Open Merge Editor"
            },
            {
                "command": "mergePro.prevConflict",
                "title": "MergePro: Previous Conflict"
            },
            {
                "command": "mergePro.nextConflict",
                "title": "MergePro: Next Conflict"
            }
        ],
        "keybindings": [
            {
                "command": "mergePro.prevConflict",
                "key": "alt+up",
                "when": "mergePro.editorActive"
            },
            {
                "command": "mergePro.nextConflict",
                "key": "alt+down",
                "when": "mergePro.editorActive"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run build",
        "build": "tsc -p tsconfig.json && vite build",
        "build:ext": "tsc -p tsconfig.json && tsc -p tsconfig.integration.json",
        "build:webview": "vite build",
        "watch:ext": "tsc -watch -p tsconfig.json",
        "watch:webview": "vite build --watch",
        "test": "vitest run && vitest run --config vitest.webview.config.ts",
        "test:watch": "vitest",
        "test:integration": "node ./out/test/integration/runTests.js",
        "lint": "eslint src webview",
        "format": "prettier . --write"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/diff": "8.0.0",
        "@types/diff-match-patch": "1.0.36",
        "@types/glob": "9.0.0",
        "@types/mocha": "10.0.10",
        "@types/node": "25.7.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@types/vscode": "1.85.0",
        "@eslint/js": "9.39.4",
        "@typescript-eslint/eslint-plugin": "8.59.3",
        "@typescript-eslint/parser": "8.59.3",
        "typescript-eslint": "8.59.3",
        "@vitejs/plugin-react": "6.0.1",
        "@vitest/coverage-v8": "4.1.6",
        "@vscode/test-electron": "2.5.2",
        "@vscode/vsce": "3.9.1",
        "eslint": "9.39.4",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.1.1",
        "globals": "17.6.0",
        "glob": "13.0.6",
        "jsdom": "29.1.1",
        "mocha": "11.7.5",
        "prettier": "3.8.3",
        "prettier-plugin-organize-imports": "4.3.0",
        "typescript": "6.0.3",
        "vite": "8.0.12",
        "vite-plugin-monaco-editor": "1.1.0",
        "vitest": "4.1.6"
    },
    "dependencies": {
        "diff": "9.0.0",
        "diff-match-patch": "1.0.5",
        "monaco-editor": "0.55.1",
        "react": "19.2.6",
        "react-dom": "19.2.6"
    },
    "overrides": {
        "dompurify": "3.4.2",
        "serialize-javascript": "7.0.5",
        "diff": "9.0.0"
    }
}
