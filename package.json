{
    "name": "merge-pro",
    "displayName": "MergePro",
    "publisher": "ismailcherri",
    "description": "IntelliJ-style three-pane merge conflict resolver for VS Code.",
    "version": "0.1.0",
    "license": "MIT",
    "icon": "assets/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/ismailcherri/merge-pro.git"
    },
    "bugs": {
        "url": "https://github.com/ismailcherri/merge-pro/issues"
    },
    "homepage": "https://github.com/ismailcherri/merge-pro#readme",
    "qna": "marketplace",
    "galleryBanner": {
        "color": "#3C2F2F",
        "theme": "dark"
    },
    "engines": {
        "vscode": "^1.85.0",
        "node": ">=20.0.0"
    },
    "categories": [
        "SCM Providers",
        "Other"
    ],
    "keywords": [
        "git",
        "merge",
        "conflict",
        "diff",
        "three-way",
        "intellij",
        "resolve",
        "merge-tool",
        "vcs"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "views": {
            "scm": [
                {
                    "type": "webview",
                    "id": "mergePro.panel",
                    "name": "MergePro",
                    "when": "true"
                }
            ]
        },
        "commands": [
            {
                "command": "mergePro.openEditor",
                "title": "MergePro: Open Merge Editor"
            },
            {
                "command": "mergePro.prevConflict",
                "title": "MergePro: Previous Conflict"
            },
            {
                "command": "mergePro.nextConflict",
                "title": "MergePro: Next Conflict"
            }
        ],
        "keybindings": [
            {
                "command": "mergePro.prevConflict",
                "key": "alt+up",
                "when": "mergePro.editorActive"
            },
            {
                "command": "mergePro.nextConflict",
                "key": "alt+down",
                "when": "mergePro.editorActive"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run build",
        "build": "tsc -p tsconfig.json && vite build",
        "build:ext": "tsc -p tsconfig.json && tsc -p tsconfig.integration.json",
        "build:webview": "vite build",
        "watch:ext": "tsc -watch -p tsconfig.json",
        "watch:webview": "vite build --watch",
        "test": "vitest run && vitest run --config vitest.webview.config.ts",
        "test:watch": "vitest",
        "test:integration": "node ./out/test/integration/runTests.js",
        "lint": "eslint src webview --ext ts,tsx",
        "format": "prettier . --write"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/diff": "^7.0.2",
        "@types/diff-match-patch": "^1.0.36",
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.0.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "@vitejs/plugin-react": "^4.7.0",
        "@vitest/coverage-v8": "^1.0.0",
        "@vscode/test-electron": "^2.3.0",
        "@vscode/vsce": "^2.22.0",
        "eslint": "^8.0.0",
        "glob": "^13.0.6",
        "jsdom": "^23.0.0",
        "mocha": "^11.7.5",
        "prettier": "^3.8.3",
        "prettier-plugin-organize-imports": "^4.3.0",
        "typescript": "^5.3.0",
        "vite": "^7.3.2",
        "vite-plugin-monaco-editor": "^1.1.0",
        "vitest": "^1.0.0"
    },
    "dependencies": {
        "diff": "^5.1.0",
        "diff-match-patch": "^1.0.5",
        "monaco-editor": "^0.45.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    }
}
