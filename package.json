{
  "name": "merge-pro",
  "displayName": "MergePro",
  "description": "IntelliJ-style three-pane merge conflict resolver",
  "version": "0.1.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": ["git", "merge", "conflict", "diff"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "scm": [
        {
          "type": "webview",
          "id": "mergePro.panel",
          "name": "MergePro",
          "when": "true"
        }
      ]
    },
    "commands": [
      { "command": "mergePro.openEditor", "title": "MergePro: Open Merge Editor" },
      { "command": "mergePro.prevConflict", "title": "MergePro: Previous Conflict" },
      { "command": "mergePro.nextConflict", "title": "MergePro: Next Conflict" }
    ],
    "keybindings": [
      { "command": "mergePro.prevConflict", "key": "alt+up", "when": "mergePro.editorActive" },
      { "command": "mergePro.nextConflict", "key": "alt+down", "when": "mergePro.editorActive" }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p tsconfig.json && webpack --config webpack.webview.config.js --mode production",
    "build:ext": "tsc -p tsconfig.json",
    "build:webview": "webpack --config webpack.webview.config.js --mode development",
    "watch:ext": "tsc -watch -p tsconfig.json",
    "watch:webview": "webpack --watch --config webpack.webview.config.js --mode development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "node ./out/test/integration/runTests.js",
    "lint": "eslint src webview --ext ts,tsx"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.22.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.0.0",
    "jsdom": "^23.0.0",
    "monaco-editor-webpack-plugin": "^7.1.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "diff": "^5.1.0",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
