{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "outDir": "./out",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "lib": ["ES2020"],
        "types": ["node", "vscode"],
        "sourceMap": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "webview", "out"]
}
