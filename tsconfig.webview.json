{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ES2022",
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "lib": ["ES2022", "DOM"],
        "sourceMap": true
    },
    "include": ["webview/**/*"],
    "exclude": ["node_modules"]
}
